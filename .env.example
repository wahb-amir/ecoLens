# ----------------------------
# Server / Environment
# ----------------------------
NODE_ENV=development          # Set to 'development' or 'production'
ORIGIN=http://localhost:3000  # Your frontend origin (used for CORS)

# ----------------------------
# API / App Secrets
# ----------------------------
PREDICT_URL=https://wahb-amir-ecolens.hf.space/run/predict  # URL for AI prediction API
ACCESS_TOKEN_SECRET=your_access_token_secret                 # Secret for signing JWT access tokens
REFRESH_TOKEN_SECRET=your_refresh_token_secret               # Secret for signing JWT refresh tokens
VERIFICATION_TOKEN_SECRET=your_verification_token_secret     # Secret for signing OTP / verification tokens

# ----------------------------
# Database
# ----------------------------
MONGODB_URI=mongodb+srv://user:password@cluster0.mongodb.net/dbname  # MongoDB connection URI

# ----------------------------
# Email / SMTP (for OTPs, password reset, notifications)
# ----------------------------
EMAIL_USER=your_email@example.com        # Email address used to send OTPs / notifications
EMAIL_PASS=your_email_password           # Password or app-specific password
EMAIL_FROM="EcoLens <no-reply@ecolens.com>" # From header for emails

SMTP_HOST=smtp.example.com               # SMTP server host
SMTP_PORT=465                             # SMTP port (465 for SSL, 587 for TLS)
SMTP_SECURE=true                          # true if using SSL/TLS
EMAIL_SERVICE=gmail                        # Optional: email service (e.g., 'gmail')
SMTP_POOL=true                             # true if using pooled SMTP connections
SMTP_MAX_CONNECTIONS=5                     # Max simultaneous SMTP connections
SMTP_MAX_MESSAGES=100                      # Max messages per connection